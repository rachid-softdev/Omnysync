{
  "name": "omnysync",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @omnysync/web dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @omnysync/web build",
    "build:core": "pnpm --filter @omnysync/core build",
    "start": "pnpm --filter @omnysync/web start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test --parallel -- --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5"
  }
}