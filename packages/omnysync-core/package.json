{
  "name": "@omnysync/core",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./prisma": {
      "import": "./dist/prisma.mjs",
      "require": "./dist/prisma.js",
      "default": "./dist/prisma.js"
    },
    "./hooks": {
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.js",
      "default": "./dist/hooks.js"
    },
    "./auth/subscription": {
      "import": "./dist/auth/subscription.mjs",
      "require": "./dist/auth/subscription.js",
      "default": "./dist/auth/subscription.js"
    },
    "./entitlements/types": {
      "import": "./dist/entitlements/types.mjs",
      "require": "./dist/entitlements/types.js",
      "default": "./dist/entitlements/types.js"
    },
    "./entitlements/constants": {
      "import": "./dist/entitlements/constants.mjs",
      "require": "./dist/entitlements/constants.js",
      "default": "./dist/entitlements/constants.js"
    },
    "./entitlements/errors": {
      "import": "./dist/entitlements/errors.mjs",
      "require": "./dist/entitlements/errors.js",
      "default": "./dist/entitlements/errors.js"
    },
    "./entitlements/CacheService": {
      "import": "./dist/entitlements/CacheService.mjs",
      "require": "./dist/entitlements/CacheService.js",
      "default": "./dist/entitlements/CacheService.js"
    },
    "./entitlements/FeatureGateService": {
      "import": "./dist/entitlements/FeatureGateService.mjs",
      "require": "./dist/entitlements/FeatureGateService.js",
      "default": "./dist/entitlements/FeatureGateService.js"
    },
    "./entitlements/EntitlementRepository": {
      "import": "./dist/entitlements/EntitlementRepository.mjs",
      "require": "./dist/entitlements/EntitlementRepository.js",
      "default": "./dist/entitlements/EntitlementRepository.js"
    },
    "./entitlements": {
      "import": "./dist/entitlements/index.mjs",
      "require": "./dist/entitlements/index.js",
      "default": "./dist/entitlements/index.js"
    },
    "./entitlements/ExperimentService": {
      "import": "./dist/entitlements/ExperimentService.mjs",
      "require": "./dist/entitlements/ExperimentService.js",
      "default": "./dist/entitlements/ExperimentService.js"
    },
    "./ui": {
      "import": "./dist/ui.mjs",
      "require": "./dist/ui.js",
      "default": "./dist/ui.js"
    },
    "./crypto": {
      "import": "./dist/crypto.mjs",
      "require": "./dist/crypto.js",
      "default": "./dist/crypto.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "import": "./dist/services/*.mjs",
      "require": "./dist/services/*.js",
      "default": "./dist/services/*.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --incremental --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.38.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "openai": "^6.42.0",
    "otpauth": "^9.5.1",
    "pg": "^8.20.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@omnysync/config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
