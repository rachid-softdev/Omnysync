# ==============================================
# OMNYSYNC - Desktop Environment Example
# ==============================================
# Copy this file to .env and fill in the values

# ---------------- API ----------------
NEXT_PUBLIC_API_URL=https://api.omnysync.com
API_BASE_URL=https://api.omnysync.com
# ---------------- AUTH ----------------
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://app.omnysync.com
# ---------------- GOOGLE OAuth ----------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# ---------------- STORAGE ----------------
AWS_REGION=eu-west-3
AWS_S3_BUCKET=omnysync-uploads
# ---------------- APP CONFIG ----------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Omnysync Desktop